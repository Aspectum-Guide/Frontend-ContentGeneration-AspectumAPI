# Default API Configuration для Vite
# Используется по умолчанию, переопределяется в .env.local
VITE_API_URL=https://dev.aspectum-guide.com/api/v1

# Опционально: DSN проекта Sentry для отчётов об ошибках в проде.
# Если не задан — error reporting не инициализируется (no-op), сборка/запуск не требуют аккаунта Sentry.
VITE_SENTRY_DSN=
